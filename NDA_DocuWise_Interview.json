{
  "template_name": "Pogodba o varovanju zaupnih informacij (NDA)",
  "language": "sl",
  "output_formats": ["pdf", "docx"],
  "pages": [
    {
      "page_id": "page_splosno",
      "title": "Splošni podatki pogodbe",
      "description": "Določite osnovne parametre pogodbe – kdaj se sklepa, kakšen tip NDA je in kakšen je namen sodelovanja.",
      "order": 1,
      "show_if": null
    },
    {
      "page_id": "page_razkrivajoca",
      "title": "Razkrivající stranka",
      "description": "Vnesite podatke o stranki, ki bo zaupne informacije posredovala drugi strani. Podatke vnesite točno tako, kot so vpisani v sodni register.",
      "order": 2,
      "show_if": null
    },
    {
      "page_id": "page_prejemajoca",
      "title": "Prejemající stranka",
      "description": "Vnesite podatke o stranki, ki bo zaupne informacije prejemala in se zavezala k njihovemu varovanju.",
      "order": 3,
      "show_if": null
    },
    {
      "page_id": "page_kontakti",
      "title": "Kontaktne osebe",
      "description": "Navedite osebe, ki bodo skrbele za izvajanje pogodbe ali bodo imele dostop do zaupnih informacij. Vsaj ena kontaktna oseba je obvezna.",
      "order": 4,
      "show_if": null
    },
    {
      "page_id": "page_zaupne_info",
      "title": "Zaupne informacije",
      "description": "Natančno opredelite, katere vrste informacij so predmet varovanja. Bolj konkretne kot so kategorije, bolj je pogodba izvršljiva.",
      "order": 5,
      "show_if": null
    },
    {
      "page_id": "page_trajanje",
      "title": "Trajanje in prenehanje",
      "description": "Določite, kako dolgo bo pogodba veljala in kaj se zgodi po njenem izteku.",
      "order": 6,
      "show_if": null
    },
    {
      "page_id": "page_digitalna_varnost",
      "title": "Digitalna varnost",
      "description": "To stran izpolnite, kadar zaupne informacije vključujejo digitalne podatke, programsko kodo ali dostope do sistemov.",
      "order": 7,
      "show_if": {
        "logic": "and",
        "conditions": [
          {
            "variable": "zahteve_digitalne_varnosti",
            "operator": "equals",
            "value": true
          }
        ]
      }
    },
    {
      "page_id": "page_podizvajalci",
      "title": "Podizvajalci in tretje osebe",
      "description": "Določite, ali sme prejemající stranka zaupne informacije posredovati svojim podizvajalcem ali zunanjim svetovalcem.",
      "order": 8,
      "show_if": null
    },
    {
      "page_id": "page_seznam_podizvajalcev",
      "title": "Seznam dovoljenih podizvajalcev",
      "description": "Navedite vse podizvajalce, ki smejo imeti dostop do zaupnih informacij. Za vsakega vpišite naziv in razlog dostopa.",
      "order": 9,
      "show_if": {
        "logic": "and",
        "conditions": [
          {
            "variable": "dovoli_podizvajalce",
            "operator": "equals",
            "value": true
          }
        ]
      }
    },
    {
      "page_id": "page_sankcije",
      "title": "Sankcije in odgovornost",
      "description": "Določite finančne posledice kršitve pogodbe. Priporočamo lestvico po stopnjah resnosti kršitve.",
      "order": 10,
      "show_if": null
    },
    {
      "page_id": "page_spori",
      "title": "Reševanje sporov in merodajno pravo",
      "description": "Izberite, kako bosta stranki reševali morebitne spore, in določite merodajno pravo.",
      "order": 11,
      "show_if": null
    },
    {
      "page_id": "page_podpisi",
      "title": "Posebne določbe in podpisi",
      "description": "Konfigurirajte formalne vidike podpisa in vpišite morebitne dodatne dogovore.",
      "order": 12,
      "show_if": null
    },
    {
      "page_id": "page_priloge",
      "title": "Priloge",
      "description": "Kadar pogodba sama po sebi ni dovolj za natančno opredelitev predmeta varovanja, dodajte eno ali več prilog.",
      "order": 13,
      "show_if": null
    }
  ],
  "variables": [
